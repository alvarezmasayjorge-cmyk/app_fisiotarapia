// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}



model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  password       String
  phone          String?   // celular / WhatsApp (con código de país, ej. +51999999999)
  role           String    @default("PATIENT") // ADMIN o PATIENT
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  patientProfile PatientProfile?
  
  // As Physio
  physioPlans        TreatmentPlan[] @relation("PhysioPlans")
  physioAppointments Appointment[]   @relation("PhysioAppointments")
  
  // As Patient (for simple login handling)
  patientAppointments Appointment[]  @relation("PatientAppointments")
  
  // Messages
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  pushSubscriptions PushSubscription[]
}

model PatientProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  diagnosis              String
  startDate              DateTime  @default(now())
  notes                  String?
  isActive               Boolean   @default(true)
  currentStreak          Int       @default(0)
  longestStreak          Int       @default(0)
  lastExerciseReminder   DateTime?

  treatmentPlans TreatmentPlan[]
  progressLogs   ProgressLog[]
  medications    Medication[]
  dailyCheckIns  DailyCheckIn[]
}

model Exercise {
  id             String    @id @default(cuid())
  name           String    @unique
  description    String
  sets           Int?
  reps           Int?
  duration       String?   // e.g. "30s"
  frequency      String?   // e.g. "3 veces por semana"
  imageUrl       String?
  videoUrl       String?
  tags           String?   // comma-separated, e.g. "cervical,lumbar"
  isHomeOnly     Boolean   @default(true)
  
  planExercises  PlanExercise[]
}

model TreatmentPlan {
  id             String    @id @default(cuid())
  patientId      String
  patient        PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  physioId       String
  physio         User      @relation("PhysioPlans", fields: [physioId], references: [id])

  pillar         String    @default("PAIN") // PELVIC_FLOOR | PAIN | AESTHETIC
  diagnosis      String    @default("")     // diagnóstico libre por pilar
  treatmentText  String    @default("")     // tratamiento abierto que escribe la doctora

  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  exercises      PlanExercise[]
  restrictions   Restriction[]
  nutrition      NutritionSupplement[]

  @@index([patientId, pillar, isActive])
}

model PlanExercise {
  id             String    @id @default(cuid())
  planId         String
  plan           TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  exerciseId     String
  exercise       Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  
  completedLogs  ExerciseLog[]
}

model Restriction {
  id             String    @id @default(cuid())
  planId         String
  plan           TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  description    String
  severity       String    @default("WARNING") // WARNING, IMPORTANT, CRITICAL
}

model NutritionSupplement {
  id             String    @id @default(cuid())
  planId         String
  plan           TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  type           String    // 'DIET_RECOMMENDED', 'DIET_AVOID', 'SUPPLEMENT'
  description    String
  time           String?   // '08:00', 'Después de cenar'
  dose           String?
}

model Appointment {
  id             String    @id @default(cuid())
  physioId       String
  physio         User      @relation("PhysioAppointments", fields: [physioId], references: [id])
  patientId      String
  patient        User      @relation("PatientAppointments", fields: [patientId], references: [id])

  date           DateTime
  mode           String    @default("PRESENTIAL") // PRESENTIAL o VIDEO
  status         String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  reminded24h    Boolean   @default(false)
  reminded2h     Boolean   @default(false)

  @@index([date, status])
}

model ProgressLog {
  id             String    @id @default(cuid())
  patientId      String
  patient        PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date           DateTime  @default(now())
  percentage     Int       @default(0)
  painLevel      Int?      // 1 to 10
  patientNotes   String?
  physioNotes    String?
}

model ExerciseLog {
  id             String    @id @default(cuid())
  planExerciseId String
  planExercise   PlanExercise @relation(fields: [planExerciseId], references: [id], onDelete: Cascade)
  date           DateTime  @default(now())
  completed      Boolean   @default(true)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Message {
  id             String    @id @default(cuid())
  senderId       String
  receiverId     String
  content        String
  createdAt      DateTime  @default(now())
  read           Boolean   @default(false)

  sender         User      @relation("SentMessages", fields: [senderId], references: [id])
  receiver       User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Medication {
  id              String    @id @default(cuid())
  patientId       String
  patient         PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name            String    // "Ibuprofeno"
  dose            String    // "400mg"
  frequencyHours  Int       // cada cuántas horas (1, 4, 6, 8, 12, 24)
  startAt         DateTime  // primera dosis
  endAt           DateTime?
  isActive        Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())

  doses           MedicationDoseLog[]

  @@index([patientId, isActive])
}

model MedicationDoseLog {
  id            String    @id @default(cuid())
  medicationId  String
  medication    Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  notifiedAt    DateTime?
  takenAt       DateTime?

  @@index([scheduledAt, notifiedAt])
  @@index([medicationId, scheduledAt])
}

model DailyCheckIn {
  id            String    @id @default(cuid())
  patientId     String
  patient       PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date          DateTime  @default(now())
  improvement   Int       // 1-10 (10 = máxima mejoría)
  painLevel     Int?      // opcional
  notes         String?

  @@index([patientId, date])
}
